{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": ".circled-wiki/schemas/bundle.schema.json",
  "title": "Circled Wiki OKF Bundle Frontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "type",
    "id",
    "bundle_uuid",
    "title",
    "status",
    "summary",
    "updated_at",
    "evidence"
  ],
  "properties": {
    "type": {
      "type": "string",
      "minLength": 1,
      "enum": [
        "policy",
        "guide",
        "runbook",
        "manual",
        "decision",
        "spec",
        "reference",
        "report"
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^bundle/[a-z0-9][a-z0-9_-]*/[^/]+_[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\.md$"
    },
    "bundle_uuid": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^evidence/[a-z0-9][a-z0-9_-]*/[^/]+_[0-9a-fA-F-]{36}\\.md$"
      },
      "uniqueItems": true
    },
    "evidence_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^\\[[^\\]\\r\\n]+\\]\\(evidence/[a-z0-9_-]+/[0-9]{4}/[0-9]{2}/[0-9]{2}/[^/]+\\.md\\)$"
      },
      "uniqueItems": true
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "resource": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_uuids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          },
          "uniqueItems": true
        },
        "curated_by": {
          "type": "string"
        },
        "review_state": {
          "type": "string",
          "enum": ["pending", "needs_changes", "approved", "rejected", "merged"]
        },
        "curation": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "generated_by": {"type": "string"},
            "generated_at": {"type": "string", "format": "date-time"},
            "generation_reason": {"type": "string"},
            "reviewed_by": {"type": "string"},
            "reviewed_at": {"type": "string", "format": "date-time"},
            "merged_into": {"type": "string"},
            "review_history": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["action", "actor", "at", "note"],
                "properties": {
                  "action": {"type": "string", "enum": ["needs_changes", "approve", "reject", "merge"]},
                  "actor": {"type": "string"},
                  "at": {"type": "string", "format": "date-time"},
                  "note": {"type": "string"}
                }
              }
            }
          }
        },
        "confidence": {
          "type": "string"
        },
        "decision_status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "rejected",
            "superseded"
          ]
        },
        "knowledge_revision": {
          "type": "integer",
          "minimum": 1
        },
        "visibility": {
          "type": "string",
          "enum": [
            "internal",
            "restricted"
          ]
        },
        "pii_masked": {
          "type": "boolean"
        },
        "review_requested": {
          "type": "boolean"
        },
        "review_reason": {
          "type": "string"
        },
        "review_requested_by": {
          "type": "string"
        },
        "review_requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "workflow": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "workflow_id",
            "version",
            "execution_mode",
            "required_inputs",
            "steps",
            "completion_criteria"
          ],
          "properties": {
            "workflow_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_-]*$"
            },
            "version": {
              "type": "integer",
              "minimum": 1
            },
            "execution_mode": {
              "type": "string",
              "enum": ["guided", "agent_assisted", "automated"]
            },
            "trigger_intents": {
              "type": "array",
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "required_inputs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "description"],
                "properties": {
                  "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_]*$"},
                  "description": {"type": "string", "minLength": 1}
                }
              }
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "title", "kind"],
                "properties": {
                  "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
                  "title": {"type": "string", "minLength": 1},
                  "kind": {
                    "type": "string",
                    "enum": ["action", "decision", "approval", "validation"]
                  }
                }
              }
            },
            "approval_gates": {
              "type": "array",
              "items": {"type": "string"},
              "uniqueItems": true
            },
            "completion_criteria": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {"const": "runbook"},
          "status": {"const": "active"}
        },
        "required": ["type", "status"]
      },
      "then": {
        "properties": {
          "extensions": {"required": ["workflow"]}
        }
      }
    }
  ]
}
